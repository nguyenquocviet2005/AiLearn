{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ailearn.local/schemas/intervention-report.v1.schema.json",
  "title": "InterventionReportV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "class_id",
    "lesson_id",
    "generated_at",
    "outcome_counts",
    "student_outcomes",
    "remaining_gaps",
    "next_lesson_focus",
    "printable_lesson_plan_id"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "id": { "type": "string", "minLength": 1 },
    "class_id": { "type": "string", "minLength": 1 },
    "lesson_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "outcome_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed_transfer",
        "still_struggling",
        "root_cause_reclassified",
        "incomplete",
        "teacher_escalation"
      ],
      "properties": {
        "passed_transfer": { "type": "integer", "minimum": 0 },
        "still_struggling": { "type": "integer", "minimum": 0 },
        "root_cause_reclassified": { "type": "integer", "minimum": 0 },
        "incomplete": { "type": "integer", "minimum": 0 },
        "teacher_escalation": { "type": "integer", "minimum": 0 }
      }
    },
    "student_outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["student_id", "outcome", "evidence_ids"],
        "properties": {
          "student_id": { "type": "string", "minLength": 1 },
          "outcome": {
            "type": "string",
            "enum": [
              "passed_transfer",
              "still_struggling",
              "root_cause_reclassified",
              "incomplete",
              "teacher_escalation"
            ]
          },
          "evidence_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "remaining_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill_id", "student_ids"],
        "properties": {
          "skill_id": { "type": "string", "minLength": 1 },
          "student_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "next_lesson_focus": { "type": "string", "minLength": 1 },
    "printable_lesson_plan_id": { "type": "string", "minLength": 1 }
  }
}
