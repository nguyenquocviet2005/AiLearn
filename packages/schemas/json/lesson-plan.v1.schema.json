{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ailearn.local/schemas/lesson-plan.v1.schema.json",
  "title": "TeacherLessonPlanV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "class_id",
    "lesson_id",
    "status",
    "total_duration_minutes",
    "activities",
    "generated_at"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "id": { "type": "string", "minLength": 1 },
    "class_id": { "type": "string", "minLength": 1 },
    "lesson_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "edited", "approved"] },
    "total_duration_minutes": { "type": "integer", "minimum": 1, "maximum": 45 },
    "activities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "duration_minutes",
          "root_cause_skill_id",
          "skill_id",
          "expected_evidence",
          "rationale"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "duration_minutes": { "type": "integer", "minimum": 1 },
          "root_cause_skill_id": { "type": "string", "minLength": 1 },
          "skill_id": { "type": "string", "minLength": 1 },
          "expected_evidence": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "generated_at": { "type": "string", "format": "date-time" }
  }
}
