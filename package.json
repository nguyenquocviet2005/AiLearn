{
  "name": "ailearn",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "pnpm --filter @ailearn/web build",
    "format": "pnpm --filter @ailearn/web format",
    "format:check": "pnpm --filter @ailearn/web format:check",
    "lint": "pnpm --filter @ailearn/web lint",
    "test": "pnpm --filter @ailearn/web test",
    "typecheck": "pnpm --filter @ailearn/web typecheck"
  },
  "dependencies": {
    "@supabase/server": "^1.4.0"
  }
}
